<?xml version="1.0" encoding="UTF-8"?>
<ApprovalProcess xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>true</active>
    <allowRecall>false</allowRecall>
    <allowedSubmitters>
        <type>owner</type>
    </allowedSubmitters>
    <approvalPageFields>
        <field>Name</field>
        <field>Owner</field>
        <field>Subscription_Months__c</field>
        <field>Credit_Amount__c</field>
        <field>Approval_Status__c</field>
        <field>Case__c</field>
        <field>CreatedBy</field>
        <field>GSDP_Credit_Note_Id__c</field>
        <field>Subscription_Credit_Reason__c</field>
        <field>Other_Reason__c</field>
        <field>Currency__c</field>
        <field>LastModifiedBy</field>
    </approvalPageFields>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <name>GSDP_Operations_Manager</name>
                <type>queue</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <booleanFilter>(1 OR 2 OR 3 OR 4) AND 5</booleanFilter>
            <criteriaItems>
                <field>Subscription_Credit_Request__c.Onwer_UBR__c</field>
                <operation>contains</operation>
                <value>L1 Supervisor</value>
            </criteriaItems>
            <criteriaItems>
                <field>Subscription_Credit_Request__c.Onwer_UBR__c</field>
                <operation>contains</operation>
                <value>L2 Supervisor</value>
            </criteriaItems>
            <criteriaItems>
                <field>Subscription_Credit_Request__c.Onwer_UBR__c</field>
                <operation>equals</operation>
                <value>CS Fort Myers Vendor Operations Manager</value>
            </criteriaItems>
            <criteriaItems>
                <field>Subscription_Credit_Request__c.Onwer_UBR__c</field>
                <operation>equals</operation>
                <value>CS Belize Vendor Operations Manager</value>
            </criteriaItems>
            <criteriaItems>
                <field>Subscription_Credit_Request__c.Months_In_Number__c</field>
                <operation>greaterThan</operation>
                <value>6</value>
            </criteriaItems>
        </entryCriteria>
        <ifCriteriaNotMet>GotoNextStep</ifCriteriaNotMet>
        <label>Assigned to Operations Manager</label>
        <name>Assigned_to_Operations_Manager</name>
    </approvalStep>
    <approvalStep>
        <allowDelegate>true</allowDelegate>
        <approvalActions>
            <action>
                <name>L1_Supervisor_Approved</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>Update_Status_InProgress</name>
                <type>FieldUpdate</type>
            </action>
        </approvalActions>
        <assignedApprover>
            <approver>
                <name>GSDP_L1_Supervisor</name>
                <type>queue</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <booleanFilter>1 AND 2 AND 3 AND 4</booleanFilter>
            <criteriaItems>
                <field>Subscription_Credit_Request__c.Onwer_UBR__c</field>
                <operation>contains</operation>
                <value>L1</value>
            </criteriaItems>
            <criteriaItems>
                <field>Subscription_Credit_Request__c.Months_In_Number__c</field>
                <operation>greaterThan</operation>
                <value>3</value>
            </criteriaItems>
            <criteriaItems>
                <field>Subscription_Credit_Request__c.Months_In_Number__c</field>
                <operation>lessOrEqual</operation>
                <value>12</value>
            </criteriaItems>
            <criteriaItems>
                <field>Subscription_Credit_Request__c.Onwer_UBR__c</field>
                <operation>notContain</operation>
                <value>Supervisor</value>
            </criteriaItems>
        </entryCriteria>
        <ifCriteriaNotMet>GotoNextStep</ifCriteriaNotMet>
        <label>Assigned to L1 Supervisor</label>
        <name>Assigned_to_L1_Supervisor</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
    </approvalStep>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <approvalActions>
            <action>
                <name>L2_Supervisor_Approved</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>Update_Status_InProgress</name>
                <type>FieldUpdate</type>
            </action>
        </approvalActions>
        <assignedApprover>
            <approver>
                <name>GSDP_L2_Supervisor</name>
                <type>queue</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <criteriaItems>
                <field>Subscription_Credit_Request__c.Onwer_UBR__c</field>
                <operation>contains</operation>
                <value>L2</value>
            </criteriaItems>
            <criteriaItems>
                <field>Subscription_Credit_Request__c.Months_In_Number__c</field>
                <operation>greaterThan</operation>
                <value>3</value>
            </criteriaItems>
            <criteriaItems>
                <field>Subscription_Credit_Request__c.Months_In_Number__c</field>
                <operation>lessOrEqual</operation>
                <value>12</value>
            </criteriaItems>
            <criteriaItems>
                <field>Subscription_Credit_Request__c.Onwer_UBR__c</field>
                <operation>notContain</operation>
                <value>Supervisor</value>
            </criteriaItems>
        </entryCriteria>
        <ifCriteriaNotMet>GotoNextStep</ifCriteriaNotMet>
        <label>Assigned to L2 Supervisor</label>
        <name>Assigned_to_L2_Supervisor</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
    </approvalStep>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <name>GSDP_Operations_Manager</name>
                <type>queue</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <booleanFilter>(1 OR 2) AND 3 AND 4 AND (5 OR 6)</booleanFilter>
            <criteriaItems>
                <field>Subscription_Credit_Request__c.Onwer_UBR__c</field>
                <operation>contains</operation>
                <value>L1</value>
            </criteriaItems>
            <criteriaItems>
                <field>Subscription_Credit_Request__c.Onwer_UBR__c</field>
                <operation>contains</operation>
                <value>L2</value>
            </criteriaItems>
            <criteriaItems>
                <field>Subscription_Credit_Request__c.Months_In_Number__c</field>
                <operation>greaterThan</operation>
                <value>6</value>
            </criteriaItems>
            <criteriaItems>
                <field>Subscription_Credit_Request__c.Months_In_Number__c</field>
                <operation>lessOrEqual</operation>
                <value>12</value>
            </criteriaItems>
            <criteriaItems>
                <field>Subscription_Credit_Request__c.Is_L1_Supervisor_Approved__c</field>
                <operation>equals</operation>
                <value>True</value>
            </criteriaItems>
            <criteriaItems>
                <field>Subscription_Credit_Request__c.Is_L2_Supervisor_Approved__c</field>
                <operation>equals</operation>
                <value>True</value>
            </criteriaItems>
        </entryCriteria>
        <label>Assigned to Operation Manager</label>
        <name>Assigned_to_Operation_Manager</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
    </approvalStep>
    <description>The requests which are submitted by L1 or L2 agents and with the amount not under the submitter will enter into this approval process</description>
    <enableMobileDeviceAccess>false</enableMobileDeviceAccess>
    <entryCriteria>
        <booleanFilter>(1 OR 2) AND 3 AND 4</booleanFilter>
        <criteriaItems>
            <field>Subscription_Credit_Request__c.Onwer_UBR__c</field>
            <operation>contains</operation>
            <value>L1</value>
        </criteriaItems>
        <criteriaItems>
            <field>Subscription_Credit_Request__c.Onwer_UBR__c</field>
            <operation>contains</operation>
            <value>L2</value>
        </criteriaItems>
        <criteriaItems>
            <field>Subscription_Credit_Request__c.Approval_Status__c</field>
            <operation>notEqual</operation>
            <value>Approved,Rejected,In Pending,Processing</value>
        </criteriaItems>
        <criteriaItems>
            <field>Subscription_Credit_Request__c.Months_In_Number__c</field>
            <operation>greaterThan</operation>
            <value>3</value>
        </criteriaItems>
    </entryCriteria>
    <finalApprovalActions>
        <action>
            <name>Approval_Status_InPending</name>
            <type>FieldUpdate</type>
        </action>
    </finalApprovalActions>
    <finalApprovalRecordLock>true</finalApprovalRecordLock>
    <finalRejectionActions>
        <action>
            <name>Approval_Stauts_Rejected</name>
            <type>FieldUpdate</type>
        </action>
    </finalRejectionActions>
    <finalRejectionRecordLock>false</finalRejectionRecordLock>
    <initialSubmissionActions>
        <action>
            <name>Update_Status_Submitted</name>
            <type>FieldUpdate</type>
        </action>
    </initialSubmissionActions>
    <label>Created by L1 or L2 UBR</label>
    <processOrder>3</processOrder>
    <recordEditability>AdminOnly</recordEditability>
    <showApprovalHistory>false</showApprovalHistory>
</ApprovalProcess>
