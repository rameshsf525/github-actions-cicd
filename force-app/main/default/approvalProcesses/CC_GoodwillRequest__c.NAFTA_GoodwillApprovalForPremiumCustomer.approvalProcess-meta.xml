    </approvalStep>
    <approvalStep>
        <allowDelegate>true</allowDelegate>
        <assignedApprover>
            <approver>
                <type>userHierarchyField</type>
            </approver>
        </assignedApprover>
        <entryCriteria>
            <formula>OR
(CONTAINS(CreatedBy.UserRole.DeveloperName ,&quot;NAFTA_SpecialistSeniorUSA&quot;) &amp;&amp; CC_TotalGoodwillRequested__c &gt; 2500,
 CONTAINS(CreatedBy.UserRole.DeveloperName ,&quot;CC_Supervisor_Level1_USA&quot;) &amp;&amp; CC_TotalGoodwillRequested__c &gt; 3000,
((CONTAINS(CreatedBy.UserRole.DeveloperName ,&quot;CC_Supervisor_Level2_USA&quot;)
|| CONTAINS(CreatedBy.UserRole.DeveloperName ,&quot;CC_Supervisor_Level3_USA&quot;)
|| CONTAINS(CreatedBy.UserRole.DeveloperName ,&quot;NAFTA_SupervisorLevel4USA&quot;)
|| CONTAINS(CreatedBy.UserRole.DeveloperName ,&quot;NAFTA_SupervisorLevel6USA&quot;) ) &amp;&amp; CC_TotalGoodwillRequested__c &gt; 10000)
)&amp;&amp;
if(CC_PromoCode__c == CC_TotalGoodwillRequested__c,false ,true)</formula>
        </entryCriteria>
        <ifCriteriaNotMet>GotoNextStep</ifCriteriaNotMet>
        <label>Level 1</label>
        <name>Step_3</name>
