    </approvalStep>
    <approvalStep>
        <allowDelegate>true</allowDelegate>
        <assignedApprover>
            <approver>
                <name>NAFTA_BrandAdvocateGroup</name>
                <type>queue</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <formula>IF(CC_PromoCode__c==CC_TotalGoodwillRequested__c, true, false) &amp;&amp; CC_PromoCode__c &lt; 50</formula>
        </entryCriteria>
        <label>Level 1</label>
        <name>Step_10</name>
        <rejectBehavior>
