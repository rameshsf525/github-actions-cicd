        </assignedApprover>
        <entryCriteria>
            <formula>CONTAINS( CreatedBy.UserRole.DeveloperName , &quot;CC_Specialist_USA&quot;) &amp;&amp;  CC_TotalGoodwillRequested__c &gt; 1500 &amp;&amp; 
if(CC_PromoCode__c == CC_TotalGoodwillRequested__c,false ,true)</formula>
        </entryCriteria>
        <ifCriteriaNotMet>GotoNextStep</ifCriteriaNotMet>
        <label>Level 1</label>
        <name>Step_2</name>
