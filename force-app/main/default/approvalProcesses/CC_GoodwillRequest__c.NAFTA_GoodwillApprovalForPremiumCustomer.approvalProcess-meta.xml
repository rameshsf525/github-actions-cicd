    <description>CC-544. Approval process for premium as well as non-premium USA customers.</description>
    <enableMobileDeviceAccess>false</enableMobileDeviceAccess>
    <entryCriteria>
        <criteriaItems>
            <field>CC_GoodwillRequest__c.CC_GoodwillRequestStatus__c</field>
            <operation>equals</operation>
            <value>Draft</value>
        </criteriaItems>
        <criteriaItems>
            <field>Case.CC_Market__c</field>
            <operation>equals</operation>
            <value>USA</value>
        </criteriaItems>
        <criteriaItems>
            <field>CC_GoodwillRequest__c.CC_CreateCheckRequestChecked__c</field>
            <operation>equals</operation>
            <value>False</value>
        </criteriaItems>
        <criteriaItems>
            <field>CC_GoodwillRequest__c.CC_Goodwill_Type__c</field>
            <operation>notEqual</operation>
            <value>Goodwill Check,Goodwill Rental</value>
        </criteriaItems>
    </entryCriteria>
