    <approvalStep>
        <allowDelegate>true</allowDelegate>
        <assignedApprover>
            <approver>
                <type>userHierarchyField</type>
            </approver>
        </assignedApprover>
        <entryCriteria>
            <formula>CONTAINS(CreatedBy.UserRole.DeveloperName,&quot;CC_Advisor_Level1_USA&quot;)
&amp;&amp;  CC_TotalGoodwillRequested__c &gt; 0 &amp;&amp; 
if(CC_PromoCode__c == CC_TotalGoodwillRequested__c,false ,true)</formula>
        </entryCriteria>
        <ifCriteriaNotMet>GotoNextStep</ifCriteriaNotMet>
        <label>Level 1</label>
        <name>Step_1</name>
    </approvalStep>
