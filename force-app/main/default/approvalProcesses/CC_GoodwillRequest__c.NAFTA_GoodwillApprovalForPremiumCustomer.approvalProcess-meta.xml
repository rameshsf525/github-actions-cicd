        <assignedApprover>
            <approver>
                <name>CC_ManagerLevel2__c</name>
                <type>relatedUserField</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <formula>OR
(CONTAINS(CreatedBy.UserRole.DeveloperName ,&quot;CC_Advisor_Level1_USA&quot;) &amp;&amp; CC_TotalGoodwillRequested__c &gt; 3000,
(CONTAINS(CreatedBy.UserRole.DeveloperName ,&quot;NAFTA_SpecialistSeniorUSA&quot;)
|| CONTAINS(CreatedBy.UserRole.DeveloperName ,&quot;CC_Specialist_USA&quot;)) &amp;&amp; CC_TotalGoodwillRequested__c &gt; 10000) &amp;&amp;
if(CC_PromoCode__c == CC_TotalGoodwillRequested__c,false ,true)</formula>
        </entryCriteria>
        <ifCriteriaNotMet>GotoNextStep</ifCriteriaNotMet>
