        <assignedApprover>
            <approver>
                <name>CC_ManagerLevel2__c</name>
                <type>relatedUserField</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <formula>CONTAINS(CreatedBy.UserRole.DeveloperName ,&quot;NAFTA_SocialMediaAgentJuniorUSA&quot;)  &amp;&amp; CC_TotalGoodwillRequested__c &gt; 1500 &amp;&amp; 
