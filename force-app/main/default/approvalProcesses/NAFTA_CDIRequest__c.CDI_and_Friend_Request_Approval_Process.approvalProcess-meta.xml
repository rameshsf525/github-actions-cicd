<?xml version="1.0" encoding="UTF-8"?>
<ApprovalProcess xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>true</active>
    <allowRecall>true</allowRecall>
    <allowedSubmitters>
        <type>owner</type>
    </allowedSubmitters>
    <allowedSubmitters>
        <submitter>CC_Specialist_USA</submitter>
        <type>role</type>
    </allowedSubmitters>
    <allowedSubmitters>
        <submitter>NAFTA_SpecialistSeniorUSA</submitter>
        <type>role</type>
    </allowedSubmitters>
    <approvalPageFields>
        <field>Name</field>
        <field>NAFTA_Case__c</field>
        <field>NAFTA_RequestType__c</field>
        <field>NAFTA_PayeeType__c</field>
        <field>NAFTA_PayeeFirstName__c</field>
        <field>NAFTA_PayeeLastName__c</field>
        <field>NAFTA_CDIBrandLoyalty__c</field>
        <field>NAFTA_CDIRequestReason__c</field>
        <field>NAFTA_IsGovernmentOfficial__c</field>
    </approvalPageFields>
    <approvalStep>
        <allowDelegate>true</allowDelegate>
        <assignedApprover>
            <approver>
                <type>userHierarchyField</type>
            </approver>
        </assignedApprover>
        <description>Request for getting first level approval</description>
        <label>Request for Manager&apos;s approval</label>
        <name>NAFTA_Request_for_approval_to_Manager</name>
    </approvalStep>
    <approvalStep>
        <allowDelegate>true</allowDelegate>
        <assignedApprover>
            <approver>
                <type>userHierarchyField</type>
            </approver>
        </assignedApprover>
        <description>If the request is approved by supervisor it goes for 2nd level of approval to Operations Manger.</description>
        <label>Request for Operations Manager&apos;s approval</label>
        <name>NAFTA_Request_for_approval_to_Operations_Manager</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
    </approvalStep>
    <approvalStep>
        <allowDelegate>true</allowDelegate>
        <approvalActions>
            <action>
                <name>NAFTA_Update_Status_on_Approval_CDI_Req</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>NAFTA_Update_the_approval_date</name>
                <type>FieldUpdate</type>
            </action>
        </approvalActions>
        <assignedApprover>
            <approver>
                <name>uscustomercaretest22@cac.stellantis.com.uat</name>
                <type>user</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <description>If the request is approved by supervisor it goes for 3rd level of approval to Director.</description>
        <label>Request for Director&apos;s approval</label>
        <name>NAFTA_Request_for_approval_to_Director</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
    </approvalStep>
    <description>This is approval process for approval of CDI or friend request. This is a 3 level approval process.</description>
    <enableMobileDeviceAccess>false</enableMobileDeviceAccess>
    <entryCriteria>
        <criteriaItems>
            <field>NAFTA_CDIRequest__c.NAFTA_RequestStatus__c</field>
            <operation>equals</operation>
            <value>Submitted</value>
        </criteriaItems>
    </entryCriteria>
    <finalApprovalRecordLock>false</finalApprovalRecordLock>
    <finalRejectionActions>
        <action>
            <name>NAFTA_UpdateStatus_on_Rejection_CDI</name>
            <type>FieldUpdate</type>
        </action>
    </finalRejectionActions>
    <finalRejectionRecordLock>false</finalRejectionRecordLock>
    <label>CDI and Friend Request Approval Process</label>
    <nextAutomatedApprover>
        <useApproverFieldOfRecordOwner>false</useApproverFieldOfRecordOwner>
        <userHierarchyField>Manager</userHierarchyField>
    </nextAutomatedApprover>
    <processOrder>3</processOrder>
    <recallActions>
        <action>
            <name>CC_CDIRequestStatusRecalled</name>
            <type>FieldUpdate</type>
        </action>
    </recallActions>
    <recordEditability>AdminOrCurrentApprover</recordEditability>
    <showApprovalHistory>true</showApprovalHistory>
</ApprovalProcess>
