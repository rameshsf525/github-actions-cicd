<?xml version="1.0" encoding="UTF-8"?>
<ApprovalProcess xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>false</active>
    <allowRecall>false</allowRecall>
    <allowedSubmitters>
        <submitter>CC_Reporting_Manager</submitter>
        <type>roleSubordinatesInternal</type>
    </allowedSubmitters>
    <approvalPageFields>
        <field>Name</field>
    </approvalPageFields>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <type>userHierarchyField</type>
            </approver>
        </assignedApprover>
        <entryCriteria>
            <formula>(CONTAINS(CreatedBy.UserRole.Name,&quot;Advisor&quot;) || 
CONTAINS(CreatedBy.UserRole.Name,&quot;Social Media Agent&quot;)
) &amp;&amp;  (ISPICKVAL(CC_DailyRate__c ,&quot;Regular&quot;) || ISPICKVAL(CC_DailyRate__c ,&quot;Premium&quot;) ||
ISPICKVAL(CC_DailyRate__c ,&quot;Competitive vehicle&quot;) &amp;&amp;  CC_TotalRentalDaysProvidedByAgent__c &gt; 3) || ISPICKVAL(CC_DailyRate__c ,&quot;Other (special circumstances)&quot;)</formula>
        </entryCriteria>
        <ifCriteriaNotMet>GotoNextStep</ifCriteriaNotMet>
        <label>Step 1</label>
        <name>Step_1</name>
    </approvalStep>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <type>userHierarchyField</type>
            </approver>
        </assignedApprover>
        <entryCriteria>
            <formula>(CONTAINS(CreatedBy.UserRole.Name,&quot;Specialist Junior&quot;) ||
CONTAINS(CreatedBy.UserRole.Name,&quot;Specialist Senior&quot;) 
) &amp;&amp; (ISPICKVAL(CC_DailyRate__c ,&quot;Regular&quot;) || ISPICKVAL(CC_DailyRate__c ,&quot;Premium&quot;) || 
ISPICKVAL(CC_DailyRate__c ,&quot;Competitive vehicle&quot;) &amp;&amp; CC_TotalRentalDaysProvidedByAgent__c &gt; 10) || ISPICKVAL(CC_DailyRate__c ,&quot;Other (special circumstances)&quot;)</formula>
        </entryCriteria>
        <ifCriteriaNotMet>GotoNextStep</ifCriteriaNotMet>
        <label>Step 2</label>
        <name>Step_2</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
    </approvalStep>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <type>userHierarchyField</type>
            </approver>
        </assignedApprover>
        <entryCriteria>
            <formula>(CONTAINS(CreatedBy.UserRole.Name,&quot;Area Manager&quot;) || 
CONTAINS(CreatedBy.UserRole.Name,&quot;CRM&quot;)  ||
CONTAINS(CreatedBy.UserRole.Name,&quot;Level3 Agent&quot;) ||
CONTAINS(CreatedBy.UserRole.Name,&quot;Top Care Agent&quot;) 
) &amp;&amp; (ISPICKVAL(CC_DailyRate__c ,&quot;Regular&quot;) || ISPICKVAL(CC_DailyRate__c ,&quot;Premium&quot;) || 
ISPICKVAL(CC_DailyRate__c ,&quot;Competitive vehicle&quot;) &amp;&amp; CC_TotalRentalDaysProvidedByAgent__c &gt; 20) || ISPICKVAL(CC_DailyRate__c ,&quot;Other (special circumstances)&quot;)</formula>
        </entryCriteria>
        <ifCriteriaNotMet>GotoNextStep</ifCriteriaNotMet>
        <label>Step 3</label>
        <name>Step_3</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
    </approvalStep>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <name>NAFTA_OperationsManager__c</name>
                <type>relatedUserField</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <formula>CONTAINS(CreatedBy.UserRole.Name,&quot;Supervisor&quot;)  &amp;&amp; (ISPICKVAL(CC_DailyRate__c ,&quot;Regular&quot;) || ISPICKVAL(CC_DailyRate__c ,&quot;Premium&quot;) || 
ISPICKVAL(CC_DailyRate__c ,&quot;Competitive vehicle&quot;) &amp;&amp; CC_TotalRentalDaysProvidedByAgent__c &gt; 10) || ISPICKVAL(CC_DailyRate__c ,&quot;Other (special circumstances)&quot;)</formula>
        </entryCriteria>
        <ifCriteriaNotMet>GotoNextStep</ifCriteriaNotMet>
        <label>Step 4</label>
        <name>Step_4</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
    </approvalStep>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <name>NAFTA_OperationsManager__c</name>
                <type>relatedUserField</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <formula>CONTAINS(CreatedBy.UserRole.Name,&quot;Special Investigation&quot;) &amp;&amp; (ISPICKVAL(CC_DailyRate__c ,&quot;Regular&quot;) || ISPICKVAL(CC_DailyRate__c ,&quot;Premium&quot;) || 
ISPICKVAL(CC_DailyRate__c ,&quot;Competitive vehicle&quot;) &amp;&amp; CC_TotalRentalDaysProvidedByAgent__c &gt; 3) || ISPICKVAL(CC_DailyRate__c ,&quot;Other (special circumstances)&quot;)</formula>
        </entryCriteria>
        <label>Step 5</label>
        <name>Step_5</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
    </approvalStep>
    <enableMobileDeviceAccess>false</enableMobileDeviceAccess>
    <entryCriteria>
        <criteriaItems>
            <field>CC_RentalCarRequest__c.NAFTA_PremiumVehicleRental__c</field>
            <operation>notEqual</operation>
            <value>True</value>
        </criteriaItems>
    </entryCriteria>
    <finalApprovalActions>
        <action>
            <name>CC_Rental_Car_Request_Status_Approved</name>
            <type>FieldUpdate</type>
        </action>
    </finalApprovalActions>
    <finalApprovalRecordLock>true</finalApprovalRecordLock>
    <finalRejectionActions>
        <action>
            <name>CC_Rental_Car_Request_Status_Rejected</name>
            <type>FieldUpdate</type>
        </action>
    </finalRejectionActions>
    <finalRejectionRecordLock>false</finalRejectionRecordLock>
    <label>Rental Approval For NonPremium Customers</label>
    <nextAutomatedApprover>
        <useApproverFieldOfRecordOwner>false</useApproverFieldOfRecordOwner>
        <userHierarchyField>Manager</userHierarchyField>
    </nextAutomatedApprover>
    <processOrder>5</processOrder>
    <recordEditability>AdminOnly</recordEditability>
    <showApprovalHistory>false</showApprovalHistory>
</ApprovalProcess>
