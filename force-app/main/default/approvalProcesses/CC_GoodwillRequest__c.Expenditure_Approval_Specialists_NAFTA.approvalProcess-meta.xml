<?xml version="1.0" encoding="UTF-8"?>
<ApprovalProcess xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>false</active>
    <allowRecall>false</allowRecall>
    <allowedSubmitters>
        <submitter>CC_Specialist_USA</submitter>
        <type>role</type>
    </allowedSubmitters>
    <approvalPageFields>
        <field>Name</field>
        <field>CC_Case__c</field>
        <field>CC_TotalGoodwillRequested__c</field>
        <field>NAFTA_PremiumVehicleGoodwill__c</field>
        <field>NAFTA_AlfaGoodwill__c</field>
    </approvalPageFields>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <type>userHierarchyField</type>
            </approver>
        </assignedApprover>
        <entryCriteria>
            <formula>AND( 
(CONTAINS($UserRole.Name , &apos;Specialist&apos;)), (CC_TotalGoodwillRequested__c  &gt;= 1500)
)</formula>
        </entryCriteria>
        <ifCriteriaNotMet>ApproveRecord</ifCriteriaNotMet>
        <label>Step 1</label>
        <name>Step_1</name>
    </approvalStep>
    <enableMobileDeviceAccess>false</enableMobileDeviceAccess>
    <entryCriteria>
        <criteriaItems>
            <field>CC_GoodwillRequest__c.CC_ContributionGivenBy__c</field>
            <operation>equals</operation>
            <value>Customer Care</value>
        </criteriaItems>
        <criteriaItems>
            <field>CC_GoodwillRequest__c.RecordType</field>
            <operation>equals</operation>
            <value>NAFTA</value>
        </criteriaItems>
        <criteriaItems>
            <field>User.CC_Role__c</field>
            <operation>contains</operation>
            <value>Specialist</value>
        </criteriaItems>
    </entryCriteria>
    <finalApprovalActions>
        <action>
            <name>CC_Goodwill_Approved_Checked</name>
            <type>FieldUpdate</type>
        </action>
    </finalApprovalActions>
    <finalApprovalRecordLock>true</finalApprovalRecordLock>
    <finalRejectionActions>
        <action>
            <name>CC_Goodwill_Request_Status_to_Rejected</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>CC_Record_Type_to_NAFTA</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>CC_Total_Goodwill_Approved_to_be_blank</name>
            <type>FieldUpdate</type>
        </action>
    </finalRejectionActions>
    <finalRejectionRecordLock>false</finalRejectionRecordLock>
    <initialSubmissionActions>
        <action>
            <name>CC_Goodwill_Request_Status_Submitted</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>CC_NAFTA_RT_to_Submit_for_Approval</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>CC_Total_Goodwill_Approved_to_be_stamped</name>
            <type>FieldUpdate</type>
        </action>
    </initialSubmissionActions>
    <label>Expenditure Approval Specialists NAFTA</label>
    <nextAutomatedApprover>
        <useApproverFieldOfRecordOwner>false</useApproverFieldOfRecordOwner>
        <userHierarchyField>Manager</userHierarchyField>
    </nextAutomatedApprover>
    <processOrder>3</processOrder>
    <recordEditability>AdminOrCurrentApprover</recordEditability>
    <showApprovalHistory>true</showApprovalHistory>
</ApprovalProcess>
